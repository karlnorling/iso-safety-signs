{
  "name": "@iso-safety-signs/css",
  "version": "1.1.0",
  "description": "CSS background-image sprite for ISO 7010 safety signs — class-based display, no JavaScript required",
  "keywords": [
    "background-image",
    "css",
    "css-sprite",
    "emergency",
    "fire",
    "iso",
    "iso-7010",
    "mandatory",
    "pictogram",
    "prohibition",
    "safety",
    "safety-signs",
    "signs",
    "sprite",
    "utility",
    "vanilla",
    "warning",
    "workplace-safety"
  ],
  "homepage": "https://karlnorling.github.io/iso-safety-signs/",
  "bugs": {
    "url": "https://github.com/karlnorling/iso-safety-signs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/karlnorling/iso-safety-signs",
    "directory": "packages/@iso-safety-signs/css"
  },
  "files": [
    "dist/",
    "sprite.css",
    "package.json",
    "README.md"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    },
    "./sprite.css": "./sprite.css"
  },
  "scripts": {
    "compile": "tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'})); require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'}))\"",
    "test": "jest",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@iso-safety-signs/core": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  }
}
