{
  "name": "iso-safety-signs-monorepo",
  "private": true,
  "description": "ISO 7010 safety sign pictograms for React, Vue 3, Web Components, CSS sprite and SVG sprite",
  "workspaces": [
    "packages/@iso-safety-signs/*",
    "apps/*"
  ],
  "scripts": {
    "update": "tsx bin/update.ts",
    "generate": "tsx bin/generate-source.ts",
    "compile": "yarn workspaces foreach -A --topological-dev run compile",
    "build": "yarn update && yarn compile",
    "test": "yarn workspaces foreach -A run test",
    "type-check": "yarn workspaces foreach -A --include '@iso-safety-signs/*' run type-check",
    "lint": "oxlint .",
    "format": "oxfmt --write --ignore-path=.oxfmtignore .",
    "format:check": "oxfmt --check --ignore-path=.oxfmtignore .",
    "check": "manypkg check",
    "changeset": "changeset",
    "publish": "yarn changeset publish",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@manypkg/cli": "^0.23.0",
    "@types/node": "^22.10.7",
    "glob": "^13.0.6",
    "lefthook": "^2.1.6",
    "marked": "^15.0.12",
    "node-html-parser": "^7.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "sharp": "^0.33.5",
    "stylelint": "^17.7.0",
    "stylelint-config-standard": "^40.0.0",
    "svgo": "^4.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "resolutions": {
    "brace-expansion": "^2.0.3",
    "flatted": "^3.4.2",
    "js-yaml": "^4.1.1",
    "minimatch": "^9.0.7",
    "node-gyp": "^12.0.0",
    "picomatch": "^4.0.4",
    "tar": "^7.5.13"
  },
  "engines": {
    "node": ">= 24.0.0"
  },
  "packageManager": "yarn@4.6.0"
}
